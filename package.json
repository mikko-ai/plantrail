{
  "name": "@mikko/plantrail",
  "version": "0.1.2",
  "description": "Auditable agent workflow toolkit (Plan → Review → Approve → Doing → Evidence → Final)",
  "type": "module",
  "bin": {
    "plantrail": "./dist/cli.js"
  },
  "files": [
    "dist",
    "assets",
    "adapters"
  ],
  "scripts": {
    "build": "tsc && node scripts/bundle-hooks.mjs && chmod +x dist/cli.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "agent",
    "workflow",
    "cursor",
    "codex",
    "claude-code",
    "audit"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "commander": "^12.1.0"
  }
}
